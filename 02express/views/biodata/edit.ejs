<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Edit Biodata</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-5">
    <div class="card">
        <div class="card-header bg-warning">
            <h4>Edit Biodata</h4>
        </div>
        <div class="card-body">
            <form action="/biodata/update/<%= id_biodata %>" method="POST" enctype="multipart/form-data">
                
                <div class="mb-3">
                    <label class="form-label">Nama Lengkap</label>
                    <input type="text" class="form-control" name="nama" value="<%= nama %>" required>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Jenis Kelamin</label>
                    <select class="form-select" name="jenis_kelamin" required>
                        <option value="Laki-laki" <%= jenis_kelamin === 'Laki-laki' ? 'selected' : '' %>>Laki-laki</option>
                        <option value="Perempuan" <%= jenis_kelamin === 'Perempuan' ? 'selected' : '' %>>Perempuan</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Alamat</label>
                    <textarea class="form-control" name="alamat" rows="3" required><%= alamat %></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Foto Profil Saat Ini</label><br>
                    <% if(foto_profil) { %>
                        <img src="/images/uploads/<%= foto_profil %>" alt="Foto Profil" class="img-thumbnail mb-2" width="150">
                    <% } else { %>
                        <p class="text-danger">Belum ada foto.</p>
                    <% } %>
                    
                    <br>
                    <label class="form-label">Ganti Foto Profil (Opsional)</label>
                    <input class="form-control" type="file" name="foto_profil" accept="image/*">
                </div>

                <button type="submit" class="btn btn-warning">Update Data</button>
                <a href="/biodata" class="btn btn-secondary">Batal</a>
            </form>
        </div>
    </div>
</div>
</body>
</html>